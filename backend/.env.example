# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mp_system
# Alternatively use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mp_system
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_at_least_64_char_random_secret
JWT_EXPIRES_IN=8h

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=mp-system-attachments

# Presigned URL expiry in seconds (default: 300 = 5 minutes)
S3_PRESIGN_EXPIRY=300

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
